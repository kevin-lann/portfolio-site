---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import { HomeHero } from '../components/portfolio/HomeHero';
import { getEntriesBySection } from '../lib/portfolio';

const entriesBySection = await getEntriesBySection();
---

<PortfolioLayout
  pageTitle="Kevin Lan | Portfolio"
  entriesBySection={entriesBySection}
  isHome={true}
  contentLinks={[]}
>
  <HomeHero client:load colorMode="dark" />
  <h1>Welcome</h1>
  <p>Use the left sidebar to browse experience, projects, and other work.</p>
  <p>Use arrow keys to move through experience and project entries.</p>
</PortfolioLayout>
